# Gemini API Key for AI features
GEMINI_API_KEY=your-gemini-api-key

# Supabase Credentials (Client-side Config)
# You can use these keys to connect to your real Supabase database
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Public App URL for OAuth Redirects (e.g. https://your-app.run.app)
VITE_APP_URL=http://localhost:3000

NODE_ENV=development

# Admin Config
VITE_ADMIN_EMAIL=admin@nexus.local
